generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
}

model Lead {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String?
  country        String?
  budgetRange    String?
  projectOutline String
  status         String   @default("new")
  createdAt      DateTime @default(now())
}

model Project {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String
  coverImage  String?
  liveUrl     String?
  githubUrl   String?
  techStack   String[]
  featured    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  caseStudy   CaseStudy?
}

model CaseStudy {
  id           String   @id @default(cuid())
  projectId    String   @unique
  project      Project  @relation(fields: [projectId], references: [id])
  problem      String
  solution     String
  architecture String?
  result       String
  createdAt    DateTime @default(now())
}

model Metric {
  id    String @id @default(cuid())
  label String
  value String
}